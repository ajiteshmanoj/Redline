# ===========================================================================
# Redline environment
# Copy to .env.local:  cp .env.example .env.local
# ===========================================================================

# --- DEMO MODE -------------------------------------------------------------
# When true, the app serves pre-scripted fixtures and makes ZERO network calls.
# This is the bulletproof stage-demo path — no API key required.
# Set to "false" (or remove) to use the live LLM path below.
DEMO_MODE=true

# --- LIVE LLM PATH ---------------------------------------------------------
# Only used when DEMO_MODE is not "true". All provider specifics are isolated
# in lib/llm.ts — see the comment block there to switch providers.

# Your API key (OpenAI by default).
LLM_API_KEY=

# Base URL of an OpenAI-Chat-Completions-compatible endpoint.
# OpenAI (default):      https://api.openai.com/v1
# OpenRouter:            https://openrouter.ai/api/v1
# Together / Groq / etc: their /v1 base URL
LLM_BASE_URL=https://api.openai.com/v1

# Shared fallback model (used by any role left unset below).
LLM_MODEL=gpt-5.4

# --- Per-role models (deliberate use of the model lineup) ------------------
# Each role can use a different model; unset roles fall back to LLM_MODEL.
# Verify these ids exist on your account before relying on them.
#   attacker — multi-turn adversarial REASONING (the centerpiece)
LLM_MODEL_ATTACKER=gpt-5.5
#   judge    — careful evaluation, returns Structured Outputs (json_schema)
LLM_MODEL_JUDGE=gpt-5.4
#   target   — simulates the customer's (typically cheap) deployed bot:
#              fast replies + realistically breakable.
LLM_MODEL_TARGET=gpt-4.1-mini

# --- EXA (real-world OSINT recon) ------------------------------------------
# Optional. When set, the adaptive agent's recon phase runs a neural web search
# (Exa) on the target company and distills the results (via the OpenAI attacker
# model, Structured Outputs) into real competitors + data types it then uses to
# tailor attacks. Unset → bot-only recon (DEMO_MODE replays a captured fixture).
# Key: https://dashboard.exa.ai
EXA_API_KEY=

# --- ElevenLabs (guided-demo narration) ------------------------------------
# Build-time only. Used by `npm run tour:audio` to pre-generate the guided-tour
# voice clips into public/tour/*.mp3. NEVER read at runtime, so the key never
# ships to the browser. ELEVENLABS_VOICE_ID is optional (defaults to "Adam").
# Key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
